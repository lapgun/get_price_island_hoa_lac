# === Apify ===
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxx

# === Facebook Cookie (lấy từ EditThisCookie extension) ===
# Dán chuỗi cookie dạng: "datr=xxx; sb=xxx; c_user=xxx; xs=xxx; fr=xxx"
FB_COOKIE=c_user=xxxx; datr=xxx; fr=xxx; locale=vi_VN; presence=xxxx; ps_l=1; ps_n=1; sb=xxxx; wd=xxxxx; xs=

# === Facebook Group URLs (phân tách bằng dấu phẩy) ===
FB_GROUP_URLS=https://www.facebook.com/groups/794678138104317,https://www.facebook.com/groups/1420410968313542,https://www.facebook.com/groups/213786099416198

# === Apify Actor ID ===
# whoareyouanas/facebook-group-scraper  → hỗ trợ nhóm kín (cần cookie) + công khai
# apify/facebook-groups-scraper         → chỉ nhóm công khai
APIFY_ACTOR_ID=whoareyouanas/facebook-group-scraper

# === Số bài tối đa mỗi nhóm ===
MAX_POSTS_PER_GROUP=200

# === Số ngày lấy bài gần nhất ===
DAYS_TO_SCRAPE=10

# === Lấy comment hay không (true/false) ===
SCRAPE_COMMENTS=true

# === Lọc giá (tỷ VNĐ) ===
PRICE_MIN_TY=1.0
PRICE_MAX_TY=2.0

# === Gemini / OpenAI API key (tuỳ chọn – dùng AI trích giá) ===
# Bỏ trống nếu chỉ dùng regex
OPENAI_API_KEY=
GEMINI_API_KEY=

# === Google Sheets (tuỳ chọn) ===
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

# === Output ===
OUTPUT_DIR=./output
